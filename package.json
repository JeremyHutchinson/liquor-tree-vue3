{
  "name": "liquor-tree",
  "description": "A Vue.js tree component.",
  "version": "0.2.70",
  "type": "module",
  "author": "Kostiantyn <phlyze@gmail.com>",
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "main": "dist/liquor-tree.umd.cjs",
  "module": "dist/liquor-tree.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/liquor-tree.es.js",
      "require": "./dist/liquor-tree.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "mitt": "^3.0.1"
  },
  "peerDependencies": {
    "vue": "^3.3.0 || ^3.4.0 || ^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
  "browserslist": [
    ">= 1%",
    "last 1 major version",
    "not dead",
    "Explorer 11"
  ],
  "homepage": "https://amsik.github.io/liquor-tree/",
  "keywords": [
    "vue",
    "tree",
    "component",
    "vue-tree",
    "treeview"
  ],
  "library": "LiquorTree",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amsik/liquor-tree.git"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.1",
    "utf-8-validate": "^5.0.2"
  }
}
