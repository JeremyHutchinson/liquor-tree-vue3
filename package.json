{
  "name": "liquor-tree",
  "description": "A Vue.js tree component.",
  "version": "0.3.0-alpha.1",
  "author": "Kostiantyn <phlyze@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "vite demo",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "preview": "vite preview demo",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "main": "./dist/liquor-tree.umd.cjs",
  "module": "./dist/liquor-tree.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/liquor-tree.js",
      "require": "./dist/liquor-tree.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.5",
    "@vitest/ui": "^2.1.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.29.1",
    "jsdom": "^25.0.1",
    "playwright": "^1.57.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "browserslist": [
    ">= 1%",
    "last 2 versions",
    "not dead"
  ],
  "homepage": "https://amsik.github.io/liquor-tree/",
  "keywords": [
    "vue",
    "vue3",
    "tree",
    "component",
    "vue-tree",
    "treeview",
    "typescript"
  ],
  "library": "LiquorTree",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amsik/liquor-tree.git"
  }
}
